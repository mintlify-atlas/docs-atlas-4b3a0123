  "keyFeatures": [
    "JWT-based authentication with OTP email verification",
    "Real-time driver location tracking via WebSocket/STOMP",
    "Stripe payment integration with checkout sessions",
    "Role-based access control (RIDER / DRIVER)",
    "Ride lifecycle management: booking, accepting, completing, cancellation",
    "Driver location caching with geospatial nearby-driver search",
    "In-app notification center",
    "Rider and driver dashboards with live map panel",
    "Ride feedback and rating system",
    "Docker Compose deployment with PostgreSQL and Redis"
  ],
